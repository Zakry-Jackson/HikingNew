extends page_layout 

block content 
    .card
        h1 Welcome! 
        p This site is for discussing and reviewing hiking trails (and our love for them!)
        p 
            | We care about 
            b
                u your
            |  experience on the trail. Talk about where you went, what you saw, what you did, and how you felt.  :)
        p Get started by reading some recent posts from our members or creating your own!

    //- insert list of last 3 posts created by most recent date
    .card
        h1 Recent Posts 
        if !posts || posts.length === 0
            p There aren't any posts yet. Be the first to create one! 
        else 
            ul.post-list 
                each post in posts 
                    li.post-preview 
                        h3
                            a(href=`/post/${post.id}`)= post.title 
                        p.post-snip= post.blogtext.length > 200 ? post.blogtext.slice(0, 200) + "....." : post.blogtext
                        p.post-date
                            = post.author + '-' + post.publish_date.toString().slice(0, 21)
                        